#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            //    ┌──────────────────┐
            //    │  ┌────────────┐  │
            //    │  │ Seeed XIAO │  │
            //    │  │  nRF52840  │  │
            //    │  └────────────┘  │
            //    │                  │
            //    │                  │
            //    │   [1]      [2]   │
            //    │                  │
            //    │   [3]      [4]   │
            //    │                  │
            //    │   [5]      [6]   │
            //    │                  │
            //    └──────────────────┘
            bindings = <
                &kp C_PREV        &kp C_NEXT
                &kp C_VOL_DN      &kp C_VOL_UP
                &kp C_PLAY_PAUSE  &kp C_MUTE
            >;
        };

        layer_1 {
            bindings = <
                &trans  &trans &trans
                &trans  &trans &trans
            >;
        };
    };
};
