//    │  │ Seeed XIAO │  │
//    │  │  nRF52840  │  │
//    │  └────────────┘  │
//    │                  │
//    │                  │
//    │   [1]      [2]   │
//    │                  │
//    │   [3]      [4]   │
//    │                  │
//    │   [5]      [6]   │
//    │                  │
//    └──────────────────┘